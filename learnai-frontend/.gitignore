# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js Build Files
.next/
out/
build/

# Electron Build Artifacts
dist/
release/
app/dist/
electron-builder-output/

# Testing
coverage/
.nyc_output

# Environment Variables (CRITICAL - may contain API keys)
.env
.env*.local
!.env.example
!.env*.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
frontend.log

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Cache
.cache/
.turbo/
.eslintcache

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project

# Temporary files
*.tmp
tmp/
temp/

# PWA files
**/public/sw.js
**/public/workbox-*.js
**/public/sw.js.map
**/public/workbox-*.js.map

# Build info
tsconfig.tsbuildinfo

# Vercel
.vercel

# Storybook
storybook-static