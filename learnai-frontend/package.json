{
  "name": "LearnAI-Desktop",
  "version": "1.0.0",
  "type": "module",
  "description": "LearnAI - Secure Learning Management System",
  "author": {
    "name": "LearnAI Team",
    "email": "support@learnai.app"
  },
  "private": true,
  "main": "public/electron/main.ts",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run next:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "next:dev": "next dev",
    "build": "npm run next:build && npm run electron:build",
    "next:build": "next build",
    "electron:build": "electron-builder",
    "start": "next start",
    "lint": "eslint .",
    "clean": "next clean",
    "dist": "npm run build && electron-builder --publish=never",
    "dist:publish": "npm run build && electron-builder --publish=always"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-player": "^3.4.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "crypto-js": "^4.2.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.learnai.app",
    "productName": "LearnAI",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "public/electron/**/*",
      ".next/**/*",
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education"
    }
  }
}
