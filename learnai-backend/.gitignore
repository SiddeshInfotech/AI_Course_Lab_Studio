# ============================================
# Backend .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment Variables (CRITICAL - contains DB credentials, API keys)
.env
.env*.local
!.env.example

# Prisma Generated Files
/generated/prisma
prisma/migrations/**/migration.sql

# Database Files (if using local SQLite)
*.db
*.sqlite
*.sqlite3
dev.db

# File Storage - CRITICAL: DO NOT COMMIT USER DATA
uploads/
encrypted-videos/
minio-data/
storage/
public/uploads/

# Logs - may contain sensitive debugging info
*.log
npm-debug.log*
yarn-debug.log*
server.log
access.log
error.log

# Testing & Coverage
coverage/
.nyc_output
test-results/

# Build artifacts
dist/
build/
out/

# Cache
.cache/
.eslintcache

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Temporary files
*.tmp
tmp/
temp/

# Debug scripts output (optional - these might contain debugging info)
debug-*.js
investigate-*.js

# Test scripts (optional - uncomment if they contain sensitive test data)
# test-*.sh
# check-*.js