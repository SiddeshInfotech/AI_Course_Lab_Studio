generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  name           String
  username       String           @unique
  email          String?          @unique
  password       String
  rollNumber     String?          // Student roll number
  dob            DateTime?        // Date of birth
  isAdmin        Boolean          @default(false)
  created_at     DateTime         @default(now())
  enrollments    Enrollment[]
  sessions       Session[]
  dailyUsage     DailyUsage[]
  courseProgress CourseProgress[]
  lessonProgress LessonProgress[]
  toolProgress   ToolProgress[]
}

model Session {
  id               String    @id @default(cuid())
  userId           Int
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Course {
  id          Int              @id @default(autoincrement())
  title       String
  description String
  category    String
  level       String // beginner | intermediate | advanced
  imageUrl    String?
  instructor  String
  duration    String // e.g. "4 hours"
  status      String           @default("Published") // Published | Draft
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  enrollments Enrollment[]
  lessons     Lesson[]
  progress    CourseProgress[]
  toolCourses ToolCourse[]
}

model Lesson {
  id             Int              @id @default(autoincrement())
  courseId       Int
  title          String
  description    String?
  content        String? // lesson content/material
  videoUrl       String?
  orderIndex     Int // position in course (1, 2, 3...)
  duration       String? // e.g. "15 minutes"
  section        String? // e.g. "Day 1", "Week 1", "Module 1"
  sectionTitle   String? // e.g. "Foundations of Neural Networks"
  type           String           @default("video") // video, quiz, exercise, reading
  objectives     String? // JSON array of learning objectives
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@unique([courseId, orderIndex])
  @@index([courseId])
}

model Tool {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String
  category    String
  websiteUrl  String
  imageUrl    String?
  isPremium   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  toolCourses ToolCourse[]
}

model ToolCourse {
  id           Int            @id @default(autoincrement())
  courseId     Int
  toolId       Int
  orderIndex   Int // Day 1, Day 2, Day 3... (1, 2, 3...)
  section      String         @default("Day 1") // e.g. "Day 1", "Day 2"
  sectionTitle String? // e.g. "Introduction to ChatGPT"
  description  String? // Tool-specific description for this course
  demoVideoUrl String? // Demo video specific to this course/tool combo
  isPremium    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tool         Tool           @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolProgress ToolProgress[]

  @@unique([courseId, toolId])
  @@index([courseId])
  @@index([toolId])
}

model ToolProgress {
  id           Int        @id @default(autoincrement())
  userId       Int
  toolCourseId Int
  completed    Boolean    @default(false)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolCourse   ToolCourse @relation(fields: [toolCourseId], references: [id], onDelete: Cascade)

  @@unique([userId, toolCourseId])
  @@index([userId])
  @@index([toolCourseId])
}

model Enrollment {
  id         Int      @id @default(autoincrement())
  userId     Int
  courseId   Int
  enrolledAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model DailyUsage {
  id            Int       @id @default(autoincrement())
  userId        Int
  date          DateTime  @db.Date
  totalSeconds  Int       @default(0)
  lastHeartbeat DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model CourseProgress {
  id              Int       @id @default(autoincrement())
  userId          Int
  courseId        Int
  currentLessonId Int       @default(1) // orderIndex of current lesson
  completed       Boolean   @default(false)
  startedAt       DateTime  @default(now())
  lastAccessedAt  DateTime  @default(now())
  completedAt     DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id          Int       @id @default(autoincrement())
  userId      Int
  lessonId    Int
  courseId    Int
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
  @@index([lessonId])
}

model Media {
  id               Int       @id @default(autoincrement())
  filename         String    // original filename
  mimeType         String    // e.g. "video/mp4", "image/png"
  size             Int       // file size in bytes
  
  // Storage configuration
  storageType      String    @default("minio") // 'local', 'minio', 's3'
  storageKey       String?   // Storage key (S3/MinIO key or local path)
  url              String?   // Public/signed URL for accessing the file
  
  uploadedBy       Int?      // admin who uploaded
  entityType       String?   // "course", "lesson" - what this media belongs to
  entityId         Int?      // ID of the related entity

  // Video thumbnail
  thumbnailStorageKey String? // Storage key for thumbnail
  thumbnailUrl        String? // Public URL for thumbnail
  
  // Video compression and optimization fields
  originalSize     Int?      // original file size before compression
  compressionRatio Float?    // compression ratio (0.0 to 1.0)
  processingTime   Int?      // processing time in milliseconds
  isCompressed     Boolean   @default(false) // whether video was compressed

  createdAt        DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([mimeType])
}
