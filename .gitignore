*.test.js.snap
__snapshots__/

# Electron build artifacts
release/
app/dist/

# Temporary files
*.tmp
tmp/
temp/

# Cleanup scripts (one-time use, don't commit)
cleanup-git.sh
cleanup-git-history.sh
check-github-status.sh
GIT_CLEANUP_GUIDE.md

