# ============================================
# AI Course Lab Studio - Main .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Project docs and local notes
docs/

# Testing
coverage/
.nyc_output

# Next.js Build
.next/
out/
learnai-frontend/.next/
learnai-frontend/out/

# Build outputs
dist/
build/
learnai-frontend/dist/
release/
app/dist/

# Environment Variables
.env
.env*.local
!.env.example
!.env*.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Cache directories
.cache/
.turbo/
.eslintcache

# Test artifacts
*.test.js.snap
__snapshots__/

# Temporary files and archives
*.tmp
tmp/
temp/
*.zip
*.mp4

# Cleanup scripts (one-time use, don't commit)
cleanup-git.sh
cleanup-git-history.sh
check-github-status.sh
GIT_CLEANUP_GUIDE.md

# Debug/temporary scripts
debug-guide.sh
fix-admin-upload.js
test-video-fix.sh

# Test scripts with credentials (optional - uncomment to exclude all test scripts)
# test-*.sh
# test-*.js
