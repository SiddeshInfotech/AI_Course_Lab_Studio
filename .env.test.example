# Test Environment Variables
# Copy this to .env.test and fill in your test credentials

# Test API Configuration
API_BASE=http://localhost:5001/api

# Admin Test Account
TEST_ADMIN_EMAIL=admin@learnai.com
TEST_ADMIN_PASSWORD=your-test-password-here
TEST_ADMIN_USERNAME=admin

# Student Test Account
TEST_STUDENT_EMAIL=student@learnai.com
TEST_STUDENT_PASSWORD=your-test-password-here
TEST_STUDENT_USERNAME=student

# Test Device ID (for license testing)
TEST_DEVICE_ID=test-device-12345

# MinIO Test Configuration
TEST_MINIO_ENDPOINT=localhost
TEST_MINIO_PORT=9000
TEST_MINIO_ACCESS_KEY=test-access-key
TEST_MINIO_SECRET_KEY=test-secret-key
TEST_MINIO_BUCKET=test-videos
